# ═══════════════════════════════════════════════════════
# ClaimLens Environment Variables
# Copy this to .env.local for local development
# Add these same values in Vercel Dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════════════

# ── Anthropic API (your key, never exposed to browser) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NextAuth.js ──
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Postgres (auto-set when you link a Vercel Postgres DB) ──
# These are populated automatically by Vercel when you create a
# Postgres database in your project dashboard.
# For local dev, copy the values from Vercel Dashboard → Storage → your DB → .env.local tab
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
